<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- WAJIB untuk WebView -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Dipaflower">

        <!-- Reminder Receiver -->
        <receiver
            android:name=".receiver.ReminderReceiver"
            android:enabled="true"
            android:exported="false" />
        <activity
            android:name=".BaseActivity"
            android:exported="false" />
        <activity
            android:name=".OnboardingActivity"
            android:exported="false" />
        <activity
            android:name=".report.DisasterReportActivity"
            android:exported="false" />
        <!-- WEBVIEW -->
        <activity
            android:name=".Home.WebViewActivity"
            android:exported="false" /> <!-- SPLASH SCREEN -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- AUTH -->
        <activity
            android:name=".AuthActivity"
            android:exported="false" /> <!-- TUGAS P5 -->
        <activity
            android:name=".Home.tugasp5.FifthActivity"
            android:exported="true" />
        <activity
            android:name=".Home.tugasp5.WebViewActivity"
            android:exported="false" /> <!-- TUGAS P4 -->
        <activity
            android:name=".Home.tugasp4.ScreenActivity"
            android:exported="false" />
        <activity
            android:name=".Home.tugasp4.HalamanActivity"
            android:exported="false" /> <!-- TUGAS P3 -->
        <activity
            android:name=".Home.tugasp3.LoginActivity"
            android:exported="false" />
        <activity android:name=".Home.tugasp3.DashboardActivity" /> <!-- MAIN -->
        <activity android:name=".MainActivity" />
    </application>

</manifest>